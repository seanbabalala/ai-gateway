# ============================================================
# SiftGate — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These variables are referenced in gateway.config.yaml using
# ${VAR} for required values or ${VAR:-default} when a default is configured.
# ============================================================

# ── Gateway Client Auth ──
# Client Gateway API keys are generated in the Dashboard after startup.
# Do not put client keys here. This file is for provider secrets and runtime settings.

# ── AI Provider API Keys ──
# Add keys for each provider you configure in gateway.config.yaml.
# Only uncomment the ones you need.

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-...

# Anthropic (https://console.anthropic.com/settings/keys)
# ANTHROPIC_API_KEY=sk-ant-...

# Google AI / Gemini (https://aistudio.google.com/apikey)
# GOOGLE_API_KEY=AIza...

# Azure OpenAI (https://portal.azure.com)
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# ── Optional: Custom Config Path ──
# Override the default config file location (default: ./gateway.config.yaml)
# GATEWAY_CONFIG_PATH=./gateway.config.yaml

# ── Optional: PostgreSQL Runtime Database ──
# Used when database.type=postgres and by siftgate migrate-db.
# DATABASE_URL=postgresql://siftgate:replace-me@localhost:5432/siftgate
# Docker Compose postgres profile defaults:
# POSTGRES_DB=siftgate
# POSTGRES_USER=siftgate
# POSTGRES_PASSWORD=siftgate_dev_password
# POSTGRES_PORT=5432

# ── Optional: Redis Shared State / Cluster Mode ──
# Used when state.backend=redis or cluster.enabled=true.
# Redis is optional for single-node local startup.
# REDIS_URL=redis://localhost:6379
# SIFTGATE_INSTANCE_ID=siftgate-local-1

# ── Optional: Dashboard OIDC / SSO ──
# Used when dashboard.oidc.enabled=true. Prefer secret references in config.
# SIFTGATE_DASHBOARD_SESSION_SECRET=replace-with-long-random-string
# OIDC_CLIENT_ID=...
# OIDC_CLIENT_SECRET=...

# ── Optional: Hosted Control Plane ──
# Only needed when control_plane.enabled=true in gateway.config.yaml.
# GATEWAY_REGISTRATION_TOKEN=gw_reg_...
