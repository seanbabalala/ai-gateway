{
  "name": "siftgate",
  "version": "2.9.1",
  "description": "SiftGate self-hosted AI traffic gateway with smart routing",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/client"
  ],
  "bin": {
    "siftgate": "dist/cli/siftgate.js"
  },
  "aiGatewayRelease": {
    "npmPackage": false,
    "distribution": "GitHub source and Docker image",
    "privateReason": "Keep private=true until an npm package is intentionally published."
  },
  "scripts": {
    "build": "rm -rf dist-runtime-plugins src/canonical/canonical.types.js src/config/gateway.config.js src/config/modality.js src/plugins/types.js && nest build && tsc -p tsconfig.plugins.json",
    "build:sdk": "npm --workspace @siftgate/client run build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "validate:config": "ts-node src/cli/siftgate.ts validate",
    "validate:k8s": "ts-node scripts/validate-k8s.ts",
    "docs:check": "node scripts/check-docs.js",
    "release:check": "node scripts/check-release-version.js",
    "provider-registry:check": "node scripts/validate-provider-registry.js",
    "catalog": "ts-node src/cli/siftgate.ts catalog",
    "migrate:db": "ts-node src/cli/siftgate.ts migrate-db",
    "typecheck:sdk": "npm --workspace @siftgate/client run typecheck",
    "lint": "eslint \"{src,test}/**/*.ts\" \"scripts/**/*.{js,ts}\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:sdk": "npm --workspace @siftgate/client run test",
    "test:python-sdk": "python3 -m unittest discover -s packages/python/tests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "benchmark:upstream": "node scripts/benchmark-upstream.js",
    "benchmark:platform": "node scripts/benchmark-platform.js",
    "smoke:docker": "bash scripts/docker-smoke.sh"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/typeorm": "^11.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-prometheus": "^0.217.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.217.0",
    "@opentelemetry/instrumentation-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "undici": "^6.25.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/siftgate[-_]cloud/",
      "/test/e2e/"
    ],
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s",
      "!src/**/*.module.ts",
      "!src/main.ts",
      "!src/**/index.ts"
    ],
    "coverageDirectory": "./coverage",
    "coverageReporters": [
      "text",
      "text-summary",
      "lcov",
      "json-summary"
    ],
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "overrides": {
    "@opentelemetry/otlp-transformer": {
      "protobufjs": "^8.2.0"
    }
  }
}
