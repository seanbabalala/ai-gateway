{
  "name": "@siftgate/client",
  "version": "1.4.0",
  "description": "Lightweight TypeScript client for the SiftGate open-source data plane",
  "license": "MIT",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "jest --config ../../package.json --runInBand --testRegex \"packages/client/test/.*\\.spec\\.ts$\""
  }
}
